APP_NAME="Kupikupi API"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
API_V1_PREFIX="/v1"

DATABASE_URL="postgresql+asyncpg://kupikupi:kupikupi@localhost:5432/kupikupi"
